{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kaisho",
  "version": "0.2.0",
  "identifier": "com.ridingbytes.kaisho",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Kaisho",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE0N0EzNTY3QTFFRUVFMzQKUldRMDd1NmhaelY2RkxqTjBIK0l5eWwwaU5kZlcwNnVNV0FaMlJ4azFOVnRWZENDT0dqYW1wbVoK",
      "endpoints": [
        "https://github.com/ridingbytes/kaisho/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
