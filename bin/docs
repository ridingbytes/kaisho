#!/usr/bin/env bash
# ----------------------------------------------------------
# Kaisho documentation server
#
# Usage:
#   bin/docs               Serve docs locally (live-reload)
#   bin/docs build         Build static site to site/
#   bin/docs --port 8001   Serve on a custom port
# ----------------------------------------------------------

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
DIM='\033[2m'
RESET='\033[0m'

log() { echo -e "${CYAN}[docs]${RESET} $*"; }
ok()  { echo -e "${GREEN}[docs]${RESET} $*"; }
err() { echo -e "${RED}[docs]${RESET} $*" >&2; }

PORT=8000
MODE="serve"

for arg in "$@"; do
  case "$arg" in
    build)     MODE="build" ;;
    --port=*)  PORT="${arg#*=}" ;;
    --port)    ;; # next arg is the port
    -h|--help)
      echo "Usage: bin/docs [build] [--port PORT]"
      echo ""
      echo "  (default)  Serve docs with live-reload"
      echo "  build      Build static site to site/"
      echo "  --port N   Serve on port N (default: 8000)"
      exit 0
      ;;
    *)
      if [[ "$arg" =~ ^[0-9]+$ ]]; then
        PORT="$arg"
      else
        err "Unknown argument: $arg"
        exit 1
      fi
      ;;
  esac
done

# Use a dedicated venv so we don't depend on the system
# Python or pyenv shims that may not have mkdocs.
VENV="/tmp/mkdocs-venv"
if [ ! -x "$VENV/bin/mkdocs" ]; then
  log "Installing mkdocs to $VENV..."
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install -q \
    "mkdocs>=1.6" \
    "mkdocs-material>=9.5" \
    "mkdocs-minify-plugin>=0.8"
  ok "mkdocs installed"
fi
export PATH="$VENV/bin:$PATH"

cd "$PROJECT_DIR"

if [ "$MODE" = "build" ]; then
  log "Building documentation..."
  mkdocs build
  ok "Site built in ${DIM}site/${RESET}"
else
  log "Serving documentation on ${GREEN}http://localhost:${PORT}/${RESET}"
  log "Press Ctrl+C to stop"
  echo ""
  mkdocs serve --dev-addr "localhost:${PORT}"
fi
