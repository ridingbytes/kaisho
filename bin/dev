#!/usr/bin/env bash
# ============================================================
# Kaisho development launcher
#
# Usage:
#   bin/dev              Browser dev (backend + Vite, default)
#   bin/dev --desktop    Desktop app (Tauri with hot reload)
#   bin/dev --backend    Backend only  (API on :8766)
#   bin/dev --frontend   Frontend only (Vite on :5173)
#   bin/dev --prod       Production mode (backend serves
#                        built frontend on :8766)
#   bin/dev --docker     Build and run Docker container
#
# Options:
#   --port PORT          Backend port (default: 8766)
#   --profile NAME       Active profile name
#   --no-install         Skip dependency checks
#   --skip-sidecar       --desktop only: skip PyInstaller
#                        rebuild (use when only UI changed)
#
# When to use which mode:
#   browser (default)  Fast iteration on backend or frontend
#                      logic. No build step. Hot reload.
#   --desktop          Test Tauri-specific behaviour: tray
#                      icon, native file dialogs, CSV export,
#                      auto-updater. Rebuilds the sidecar
#                      (Python → binary) unless --skip-sidecar.
#                      Use --skip-sidecar when you only changed
#                      frontend or Rust code, not Python.
#   --prod             Verify the production bundle before
#                      cutting a release.
#   --docker           Test the containerised deployment.
#
# Version management:
#   bump-version.sh          Sync version across all files
#                            (runs automatically on --desktop).
#   bump-version.sh 1.2.3    Set a new release version, then
#                            commit and tag.
# ============================================================
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"

MODE="dev"
PORT="8766"
PROFILE=""
SKIP_INSTALL=false
SKIP_SIDECAR=false

BACKEND_PID=""
FRONTEND_PID=""

# -- Parse arguments ----------------------------------------

while [[ $# -gt 0 ]]; do
    case "$1" in
        --desktop)    MODE="desktop";  shift ;;
        --backend)    MODE="backend";  shift ;;
        --frontend)   MODE="frontend"; shift ;;
        --prod)       MODE="prod";     shift ;;
        --docker)     MODE="docker";   shift ;;
        --port)       PORT="$2";       shift 2 ;;
        --profile)    PROFILE="$2";    shift 2 ;;
        --no-install) SKIP_INSTALL=true; shift ;;
        --skip-sidecar) SKIP_SIDECAR=true; shift ;;
        -h|--help)
            awk '/^# =/{next} /^set -/{exit} /^#!/{next} \
                 /^#/{sub(/^# ?/,""); print}' "$0"
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

# -- Helpers ------------------------------------------------

cleanup() {
    echo ""
    echo "Shutting down..."
    [ -n "$FRONTEND_PID" ] && kill "$FRONTEND_PID" 2>/dev/null
    [ -n "$BACKEND_PID" ]  && kill "$BACKEND_PID"  2>/dev/null
    wait 2>/dev/null
    echo "Done."
}

ensure_venv() {
    if [ ! -d "$ROOT/.venv" ]; then
        echo "Creating virtual environment..."
        python3 -m venv "$ROOT/.venv"
    fi
    source "$ROOT/.venv/bin/activate"
}

ensure_deps() {
    if $SKIP_INSTALL; then return; fi

    # Python
    if ! command -v kai &>/dev/null; then
        echo "Installing kaisho..."
        pip install -e "$ROOT"
    fi

    # Node (only if frontend needed)
    if [[ "$MODE" == "dev" || "$MODE" == "frontend" ]]; then
        if [ ! -d "$ROOT/frontend/node_modules" ]; then
            echo "Installing frontend deps..."
            (cd "$ROOT/frontend" && pnpm install)
        fi
    fi

    # Frontend build (prod and desktop modes need a built bundle)
    if [[ "$MODE" == "prod" || "$MODE" == "desktop" ]]; then
        if [ ! -f "$ROOT/frontend/dist/index.html" ]; then
            echo "Building frontend..."
            (cd "$ROOT/frontend" && pnpm install && pnpm build)
        fi
    fi
}

kill_leftovers() {
    local pids
    pids=$(lsof -ti :"$PORT" 2>/dev/null || true)
    pids="$pids $(pgrep -f 'kai-server' 2>/dev/null || true)"
    pids="$pids $(pgrep -f 'kaisho-desktop' 2>/dev/null || true)"
    pids=$(echo "$pids" | xargs -n1 | sort -u | xargs)
    if [[ -n "$pids" ]]; then
        echo "Killing leftover processes: $pids"
        # shellcheck disable=SC2086
        kill $pids 2>/dev/null || true
        sleep 1
    fi
}

start_backend() {
    local extra_env=""
    [ -n "$PROFILE" ] && extra_env="PROFILE=$PROFILE"
    [[ "$MODE" == "prod" ]] && extra_env="$extra_env SERVE_FRONTEND=true"

    echo "Starting backend on http://localhost:$PORT ..."
    # shellcheck disable=SC2086
    env $extra_env kai serve --port "$PORT" &
    BACKEND_PID=$!
}

start_frontend() {
    echo "Starting frontend on http://localhost:5173 ..."
    (cd "$ROOT/frontend" && pnpm dev) &
    FRONTEND_PID=$!
}

# -- Main ---------------------------------------------------

trap cleanup EXIT INT TERM

kill_leftovers

case "$MODE" in
    dev)
        ensure_venv
        ensure_deps
        start_backend
        start_frontend
        echo ""
        echo "Kaisho is running (browser mode)."
        echo "  App:  http://localhost:5173"
        echo "  API:  http://localhost:$PORT"
        echo "  Press Ctrl+C to stop."
        wait
        ;;

    desktop)
        ensure_venv
        ensure_deps
        echo "Syncing version..."
        "$ROOT/scripts/bump-version.sh"
        if ! $SKIP_SIDECAR; then
            echo "Building frontend..."
            (cd "$ROOT/frontend" && pnpm build)
            echo "Clearing sidecar cache..."
            rm -rf ~/.kaisho/runtime/*
            echo "Building sidecar (use --skip-sidecar to skip)..."
            "$ROOT/scripts/build-sidecar.sh"
        fi
        echo "Starting Tauri dev (hot reload for Rust changes)..."
        echo "  Press Ctrl+C to stop."
        (cd "$ROOT/desktop" && pnpm dev)
        ;;

    backend)
        ensure_venv
        ensure_deps
        start_backend
        echo ""
        echo "Backend running on http://localhost:$PORT"
        echo "  Press Ctrl+C to stop."
        wait
        ;;

    frontend)
        ensure_deps
        start_frontend
        echo ""
        echo "Frontend running on http://localhost:5173"
        echo "  Press Ctrl+C to stop."
        wait
        ;;

    prod)
        ensure_venv
        ensure_deps
        echo "Starting production server on http://localhost:$PORT ..."
        echo "  Press Ctrl+C to stop."
        SERVE_FRONTEND=true \
            ${PROFILE:+PROFILE=$PROFILE} \
            kai serve --port "$PORT"
        ;;

    docker)
        echo "Building and starting Docker container..."
        docker compose up --build
        ;;
esac
